# Google Gemini API Key (Required)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (Optional — default: gemini-2.0-flash)
# Valid values: gemini-2.0-flash, gemini-pro, gemini-1.5-flash, gemini-1.5-pro
# If the chosen model is unavailable for your key, switch to gemini-pro as a fallback.
GEMINI_MODEL=gemini-2.0-flash

# Azure Speech Services (Optional - for premium TTS)
# Default TTS uses edge-tts (free, no key needed)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# TTS Provider: "edge" (default, free) or "azure" (optional)
TTS_PROVIDER=edge
